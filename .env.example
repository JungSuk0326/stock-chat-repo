# =============================================================================
# Root-level environment template — used by docker-compose only.
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# 백엔드 앱 설정은 backend/.env.example 참고.
# =============================================================================

# PostgreSQL (compose container credentials)
POSTGRES_USER=stock
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=stock_advisor
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
