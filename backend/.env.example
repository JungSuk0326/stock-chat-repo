# =============================================================================
# Stock Advisor — Backend environment template
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# =============================================================================

# Runtime
ENVIRONMENT=dev               # dev | prod
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# Markets — comma-separated. Phase 1: KR only. Phase 2: KR,US
ENABLED_MARKETS=KR

# Dev only: poll the Naver API even when KR market is closed (for smoke testing).
# Leave false in production — the API returns stale closes off-hours.
ALLOW_OFF_HOURS_POLLING=false

# Personal auth (single-user app)
AUTH_PASSWORD=change-me

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://stock:stock@localhost:5432/stock_advisor

# Redis (cache + pub/sub)
REDIS_URL=redis://localhost:6379/0

# LLM API keys — set whichever provider(s) you want offered in the UI.
# An empty key just means that provider's models won't appear in the catalog.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# LLM — default model when UI doesn't specify + combined hard caps (R2).
# Catalog auto-filters by which keys are set; the default must be a model
# from a provider whose key is configured.
LLM_DEFAULT_PROVIDER=gemini
LLM_DEFAULT_MODEL=gemini-2.5-pro
LLM_DAILY_TOKEN_CAP=100000
LLM_MONTHLY_TOKEN_CAP=2000000
LLM_MAX_OUTPUT_TOKENS=2048

# DART OpenAPI (Korean disclosure)
DART_API_KEY=

# KRX login (data.krx.co.kr free account) — required for the market-wide
# investor-type breakdown (사모/연기금/투신 etc.). Used by:
#   - daily worker `market_investor_flow_daily` (시장 전체 누적)
#   - LLM tool `discover_by_investor_flow` (종목별 랭킹)
# 가입: https://data.krx.co.kr → 우상단 회원가입 (무료, 5분)
# 비워두면 자연어 발굴은 동작하지 않음. 나머지 (3-분류 외/기/개) 경로는 무관.
KRX_ID=
KRX_PW=

# Telegram (alerts) — leave empty until you create a bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alerts — "log" (dev default) or "telegram".
# "telegram" falls back to "log" if the bot token / chat id are missing.
ALERT_CHANNEL=log

# DB backup (R5)
# In docker-compose the worker mounts ./backups → /backups. For local
# (non-docker) worker runs, set this to an existing local path.
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=14
